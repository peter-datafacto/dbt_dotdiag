strict digraph "" {
	graph [concentrate=true,
		label="User 360 Dimensions (Excluding Churn)\l \lTarget models: \l 	dim_user_360_user_accounts\l	dim_user_360_engagement\l\lParent depth: \
1, Child depth:  1\lModel filter regex: .*churn.*\l# models excluded: 2\lBorder style: [ solid = table, dashed = incremental table, \
none = view ] \l",
		labeljust=l,
		labelloc=b,
		layout=dot,
		nojustify=True,
		rankdir=LR
	];
	node [arrowhead=normal,
		shape=box,
		style=filled
	];
	edge [arrowhead=normal,
		arrowtail=dot
	];
	rpt_marketing_app_user_demographics	[fillcolor=seashell,
