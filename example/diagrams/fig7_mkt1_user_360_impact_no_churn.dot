	dim_user_360_event_users_latest -> dim_user_360_user_accounts	[arrowhead=empty];
	dim_app_users	[fillcolor="/pastel28/3",
		style="solid,bold,filled"];
	dim_app_users -> dim_user_360_engagement	[arrowhead=empty];
	dim_app_users -> fct_email_campaign_user_engagement	[arrowhead=empty];
	dim_app_users -> dim_user_360_event_users_latest	[arrowhead=empty];
