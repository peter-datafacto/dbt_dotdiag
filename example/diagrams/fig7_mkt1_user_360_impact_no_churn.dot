		style="solid,bold,filled"];
	fct_user_360_tickets_tag_user	[fillcolor="/pastel28/1",
		style="setlinewidth(0),bold,filled"];
	fct_app_actions	[fillcolor="/pastel28/1",
		style="setlinewidth(0),bold,filled"];
	fct_app_actions -> dim_user_360_engagement	[arrowhead=empty];
	dim_user_360_event_users_latest	[fillcolor="/pastel28/3",
		style="solid,bold,filled"];
	fct_app_actions -> dim_user_360_event_users_latest	[arrowhead=empty];
